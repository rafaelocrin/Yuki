{
  "ReverseProxy": {
    "Routes": {
      "posts-route": {
        "ClusterId": "posts-cluster",
        "Match": {
          "Path": "/post/{**catch-all}"
        }
      },
      "authors-route": {
        "ClusterId": "authors-cluster",
        "Match": {
          "Path": "/author/{**catch-all}"
        }
      },
      "posts-auth-route": {
        "ClusterId": "posts-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "posts-cluster": {
        "Destinations": {
          "posts-api": {
            "Address": "http://posts-api:8082"
          }
        }
      },
      "authors-cluster": {
        "Destinations": {
          "authors-api": {
            "Address": "http://authors-api:8083"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
