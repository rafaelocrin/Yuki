{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Serialization": {
    "Format": "json"
  },
  "MessageBus": {
    "Transport": "inmemory",
    "RabbitMQ": {
      "Host": "localhost",
      "Username": "guest",
      "Password": "guest"
    }
  },
  "EventStore": {
    "Provider": "inmemory"
  },
  "ReadModel": {
    "Provider": "inmemory"
  },
  "Jwt": {
    "Issuer": "blogging-api",
    "Audience": "blogging-clients",
    "SecretKey": "dev-only-secret-key-replace-in-prod-min32chars!",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*"
}
