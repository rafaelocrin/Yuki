{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "EventStore": {
    "Provider": "marten"
  },
  "ReadModel": {
    "Provider": "postgresql"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5433;Database=blogging;Username=postgres;Password=postgres"
  }
}
