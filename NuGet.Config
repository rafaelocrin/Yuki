<?xml version="1.0" encoding="utf-8"?>
<!--
  Local NuGet source for packages packed from this repo.
  Run: dotnet pack src/Shared/Shared.Domain -o local-packages
       dotnet pack src/Modules/Authors/Authors.Contracts -o local-packages
  When extracting to separate repos, replace <ProjectReference> with <PackageReference Include="Yuki.Shared.Domain" Version="1.0.0" />.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- Uncomment when local packages are packed: dotnet pack src/Shared/Shared.Domain -o local-packages -->
  <!-- <packageSources><add key="local-packages" value="./local-packages" /></packageSources> -->
</configuration>
